algoritmo "boasvindas"
var
nome: caractere
inicio
//2) FaÁa um programa que leia o nome de uma pessoa e
//mostre uma mensagem de boas
//vindas para ela:
//Ex:
//Qual È o seu nome? Jo„o da Silva
//Ol· Jo„o da Silva, È um prazer te conhecer!
Escreva("Qual o seu nome? ")
Leia(nome)
Escreva("Ol· ", nome, ", È um prazer te conhecer!")

fimalgoritmo