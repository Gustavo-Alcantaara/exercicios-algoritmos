algoritmo "076atribuicaoaleatoria"
var
i: inteiro
v: vetor[0..6] de inteiro
inicio
//76) Crie um programa que preencha automaticamente um vetor numérico com 7
//números gerados aleatoriamente pelo computador e depois mostre os valores
//gerados na tela.

enquanto i < 7 faca

aleatorio on
leia(v[i])

i <- i + 1

fimenquanto
aleatorio off

fimalgoritmo