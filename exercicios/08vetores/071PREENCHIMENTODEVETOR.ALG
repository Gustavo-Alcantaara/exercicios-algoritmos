algoritmo "071preenchimentodevetor"
var
n:vetor[0..7] de inteiro
i: inteiro
inicio
//71) Faça um programa que preencha automaticamente um vetor numérico com 8
//posiçőes, conforme abaixo:
//999 999 999 999 999 999 999 999
//0 1 2 3 4 5 6 7

i <- 0

enquanto (i < 8) faca

         aleatorio 0, 999
         leia(n[i])

         i <- i + 1

fimenquanto
           aleatorio off

fimalgoritmo