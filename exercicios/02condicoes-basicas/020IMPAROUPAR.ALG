algoritmo "020imparoupar"
var
n: inteiro
inicio
//20) Desenvolva um programa que leia um número inteiro e mostre se ele é
//PAR ou ÍMPAR.

Escreva("Digite um número: ")
Leia(n)

       Se n % 2 = 0 Entao
          Escreva("O número", n, " é PAR")
          Senao
               Escreva("O número", n, " é ÍMPAR")
       FimSe

fimalgoritmo