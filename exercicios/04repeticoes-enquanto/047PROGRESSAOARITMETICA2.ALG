algoritmo "047progressaoaritmetica2"
var
i, res: inteiro
inicio
//47) Desenvolva um aplicativo que mostre na tela o resultado da express„o 500 +
//450 + 400 + 350 + 300 + ... + 50 + 0

i <- 500
res <- i
enquanto (i > 0) faca

         escreval(i)
         i <- i - 50
         res <- res + i

fimenquanto
           escreva(res)

fimalgoritmo