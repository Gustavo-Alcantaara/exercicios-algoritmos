algoritmo "4soma"
var
n1, n2, s: inteiro
inicio
//4) Desenvolva um algoritmo que leia dois números inteiros
//e mostre o somatório
//entre eles.
//Ex:
//Digite um valor: 8
//Digite outro valor: 5
//A soma entre 8 e 5 é igual a 13.
Escreva("Digite um valor: ")
Leia(n1)
Escreva("Digite outro valor: ")
Leia(n2)
s <- n1 + n2
Escreva("A soma entre", n1, " e", n2, " é igual a", s)

fimalgoritmo