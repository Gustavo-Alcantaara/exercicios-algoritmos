algoritmo "9conversordolar"
var
r, d: real
inicio
//9) Faça um algoritmo que leia quanto dinheiro uma pessoa
//tem na carteira (em R$)
//e mostre quantos dólares ela pode comprar. Considere US$1,00 = R$3,45.
d <- 3.45
Escreva("Quanto dinheiro(em reais) vocę tem? R$")
Leia(r)
d <- r/d
Escreva("Vocę pode comprar", d," Dólares")


fimalgoritmo