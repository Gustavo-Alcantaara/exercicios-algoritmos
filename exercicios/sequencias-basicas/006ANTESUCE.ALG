algoritmo "6antesuce"
var
n: inteiro
inicio
//6) Faça um programa que leia um número inteiro
//e mostre o seu antecessor e seu
//sucessor.
//Ex:
//Digite um número: 9
//O antecessor de 9 é 8
//O sucessor de 9 é 10

Escreva("Digite um número: ")
Leia(n)
Escreval("O antecessor de", n, " é", n-1)
Escreva("O sucessor de", n, " é", n+1)
fimalgoritmo